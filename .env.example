# ─────────────────────────────────────────────────────────────
# Anthropic — Claude + Citations API (el cerebro de Obolo)
# Conseguir en: https://console.anthropic.com/  →  Settings  →  API Keys
# ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# Demo default: Haiku 4.5 — cheapest, keeps the per-query margin positive at QUERY_TOLL.
# The web UI lets you switch to Sonnet/Opus per query; the substring guard is identical.
ANTHROPIC_MODEL=claude-haiku-4-5

# ─────────────────────────────────────────────────────────────
# Arc (testnet) — L1 stablecoin-native de Circle
# Confirmar RPC, chainId y address de USDC en la doc de Arc el dia 1.
# Mientras tanto, dejar vacios: no bloquean el setup del entorno.
# ─────────────────────────────────────────────────────────────
ARC_RPC_URL=
ARC_CHAIN_ID=
USDC_ADDRESS=

# Wallet de TESTNET que firma las autorizaciones de nanopago (EIP-3009).
# NUNCA usar una wallet con fondos reales aca. Solo testnet.
PAYER_PRIVATE_KEY=

# ─────────────────────────────────────────────────────────────
# Agent mode (closed loop) — un agente-cliente EXTERNO le paga a OBOL por query.
# El agente paga el peaje (QUERY_TOLL) a la treasury; OBOL corre el loop y paga a
# los autores con su wallet operativa (PAYER). Cierra el circuito agente->OBOL->autores.
# ─────────────────────────────────────────────────────────────
# Wallet de TESTNET del agente-cliente (el comprador). Se fondea aparte en el faucet.
AGENT_PRIVATE_KEY=
# Donde cae el peaje de la query. Si se deja vacio, usa PAYER_ADDRESS (la wallet de OBOL).
OBOL_TREASURY_ADDRESS=
# Lo que el agente-cliente le paga a OBOL por query (cubre inferencia + payout a autores).
# $0.03 deja margen positivo con Haiku (inferencia ~$0.019 + autores). Modelos mas caros
# (Sonnet/Opus) cuestan mas y pueden dar margen negativo a este peaje: es esperable.
QUERY_TOLL=$0.03
# Puerto del toll server (distinto del seller de autores en 4021).
TOLL_PORT=4023

# ─────────────────────────────────────────────────────────────
# Circle (opcional, para mas adelante: Circle Wallets / Gateway)
# Conseguir en: https://console.circle.com/
# ─────────────────────────────────────────────────────────────
CIRCLE_API_KEY=

# ─────────────────────────────────────────────────────────────
# Unpaywall — descubrimiento legal de papers cerrados (legal guard).
# Exige un email REAL en cada request; rechaza example.com con 422.
# Es solo una clave de cortesia/rate, no autenticacion.
# ─────────────────────────────────────────────────────────────
UNPAYWALL_EMAIL=tu-email@real.com
